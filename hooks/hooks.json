            "async": true,
            "timeout": 600,
            "statusMessage": "Provisioning the creativity engine (one-time)…"
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/provision.ps1\"",
            "async": true,
            "timeout": 600,
            "statusMessage": "Provisioning the creativity engine (one-time)…"
          }
        ]
      }
    ]
  }
}
